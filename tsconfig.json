{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "es2024",
    "types": ["jest","node"],
    
    "baseUrl": ".", 
    "paths": {
      "@/*": ["src/services/auth-service/src/*"], 
      "@platform/logger": ["src/shared/logger/src/index.ts"],
      "@platform/errors": ["src/shared/errors/src/index.ts"],
      "@platform/middleware": ["src/shared/middleware/src/index.ts"]
    },

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Your Strict Options */
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    
    /* Since this is a backend project, you can remove "jsx" 
       unless you plan on SSR with React in the gateway. */
    "jsx": "react-jsx" 
  },
  "exclude": ["node_modules", "**/dist/*"]
}